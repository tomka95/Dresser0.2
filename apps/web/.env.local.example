# apps/web environment — copy to `.env.local` and fill in real values.
# .env.local is gitignored. Do NOT commit real keys. This .example is the only
# env file committed, and it ships with EMPTY values.
#
# Only NEXT_PUBLIC_* values are exposed to the browser. The Supabase anon key is
# the PUBLISHABLE key and is safe to ship to the client. Never put the Supabase
# service_role key (or any server secret) in a NEXT_PUBLIC_ variable.

# --- Supabase Auth (identity source) ---
# Project URL and anon/publishable key from: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Backend (FastAPI) ---
# Base URL for the FastAPI backend that still serves closet/gmail/outfit endpoints.
NEXT_PUBLIC_API_URL=

# --- Provider feature flags ---
# Sign in with Apple is wired through the same provider seam but disabled by default.
# Flip to "true" (and configure the Apple provider in the Supabase dashboard) to render
# the Apple button — no code change required. Leave false/empty until Apple's flow is set up.
NEXT_PUBLIC_APPLE_ENABLED=
