# Backend (FastAPI) environment — copy to `.env` and fill in real values.
# `.env` is gitignored; this `.example` ships with NO secrets.

# --- LLM ---------------------------------------------------------------------
LLM_PROVIDER=gemini
GEMINI_API_KEY=

# --- Gmail receipt extraction (phase 3c) -------------------------------------
# Structured-output extractor: Flash-Lite default, escalate to Flash only on a
# parse failure or low confidence. Leave blank to use the defaults below.
GEMINI_EXTRACT_MODEL=gemini-2.5-flash-lite
GEMINI_EXTRACT_ESCALATION_MODEL=gemini-2.5-flash
GMAIL_EXTRACT_CONFIDENCE_THRESHOLD=0.55
GMAIL_EXTRACT_MAX_CONCURRENCY=8
GMAIL_EXTRACT_MAX_BODY_CHARS=12000

# --- Gmail ingest tuning -----------------------------------------------------
# How many years back the receipt scan looks (read via gmail_oauth_client.
# default_since). Float; values <= 0 fall back to the default.
GMAIL_MAX_YEARS=2

# --- AI Stylist (Wave S0) ----------------------------------------------------
# Model seams for the Stylist (defined in S0; wired in later branches). EMBEDDING_DIM
# MUST match EMBEDDING_MODEL's width and the vector(N) in migration 0018.
STYLIST_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIM=768

# --- Database (Supabase Postgres) --------------------------------------------
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
DB_NAME=postgres

# --- Supabase (storage + auth identity) --------------------------------------
SUPABASE_PROJECT_REF=
SUPABASE_S3_ENDPOINT=
SUPABASE_S3_ACCESS_KEY=
SUPABASE_S3_SECRET_KEY=
SUPABASE_S3_BUCKET=
SUPABASE_PUBLIC_BASE_URL=

# --- Gmail-connect OAuth (dedicated "Tailor Gmail Ingest" Google client) ------
# SEPARATE from "Login with Google" (which is owned by Supabase). This client
# requests gmail.readonly ONLY. The backend always uses GMAIL_OAUTH_REDIRECT_URI
# below and never honors a caller-supplied redirect_uri.
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URI=http://localhost:3000/gmail/oauth/callback

# AES-256 key (base64, 32 bytes) for at-rest encryption of stored Gmail tokens.
# Generate: python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
# Keep in env ONLY — never commit it or store it in the database.
GMAIL_TOKEN_ENC_KEY=

# HMAC secret that signs the short-lived OAuth `state` (CSRF) token.
# Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
GMAIL_OAUTH_STATE_SECRET=

# NOTE: the legacy single-client GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET /
# GOOGLE_REDIRECT_URI have been RETIRED. Do not reintroduce them.

# --- Weather (Open-Meteo; NO API key) ----------------------------------------
# Real weather for the stylist, compose_outfit warmth, and the Home tile.
# Open-Meteo is free and keyless, so weather ships ENABLED with no config needed.
# Override the base URL only to self-host or point tests at a stub. TTL is the
# read-through cache freshness window (per ~1km cell).
# WEATHER_ENABLED=true
# WEATHER_API_BASE_URL=https://api.open-meteo.com/v1/forecast
# WEATHER_CACHE_TTL_SECONDS=3600

# --- Calendar-connect OAuth (dedicated "Tailor Calendar" Google client) -------
# SEPARATE from login (Supabase) and the Gmail-ingest client. Requests
# calendar.events.readonly ONLY. Backend always uses CALENDAR_OAUTH_REDIRECT_URI
# below and never honors a caller-supplied redirect_uri. Ship EMPTY.
CALENDAR_OAUTH_CLIENT_ID=
CALENDAR_OAUTH_CLIENT_SECRET=
CALENDAR_OAUTH_REDIRECT_URI=http://localhost:3000/calendar/oauth/callback

# HMAC secret signing the short-lived calendar OAuth `state` (CSRF) token.
# Independent of GMAIL_OAUTH_STATE_SECRET; the state's purpose claim
# ('calendar_oauth_connect') blocks any cross-flow replay from the Gmail flow.
# Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
CALENDAR_OAUTH_STATE_SECRET=

# Calendar token at-rest encryption reuses GMAIL_TOKEN_ENC_KEY (above) — one
# env-only AES-256 key for all stored OAuth tokens. No separate key needed.
