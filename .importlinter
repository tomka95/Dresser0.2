# Structural boundary between the shopping-feed RANKER and MONETIZATION (Wave F1c).
#
# The feed ranker (app.ranking, F2) and the outfit composer/compat score garments on
# taste / wardrobe-gap / price / fatigue. They must be PHYSICALLY UNABLE to import the
# monetization module — no code path from ranking can read a payout, commission, or
# affiliate-network field. Monetization happens only at click time, behind /out.
#
# app.ranking is an empty placeholder today (F1c) so F2's ranker is born inside this wall.
# Run locally / in CI: `lint-imports` (reads this file). Enforced in the test suite too
# (tests/test_monetization_boundary.py).

[importlinter]
root_package = app

[importlinter:contract:ranking-not-monetization]
name = Ranking and composer must not import monetization
type = forbidden
source_modules =
    app.ranking
    app.services.stylist.composer
    app.services.stylist.compat
forbidden_modules =
    app.monetization

[importlinter:contract:monetization-not-ranking]
name = Monetization must not import ranking or the composer
type = forbidden
source_modules =
    app.monetization
forbidden_modules =
    app.ranking
    app.services.stylist.composer
    app.services.stylist.compat

# --- Layering locked by P3.3 (ARCHITECTURE_AUDIT R3) --------------------------
#
# app.platform (ai_provider, usage) is the neutral cross-cutting layer that broke
# the services <-> gmail_closet <-> photo_closet cycle: it must be PHYSICALLY
# UNABLE to import back from any business/feature layer, or the cycle just moves
# one level down instead of actually breaking. app.core must stay the one true
# leaf every layer can depend on -- these contracts lock both invariants so a
# future PR can't reintroduce either cycle.

[importlinter:contract:platform-depends-on-nothing-upward]
name = Platform must not import any business/feature layer
type = forbidden
source_modules =
    app.platform
forbidden_modules =
    app.api
    app.services
    app.gmail_closet
    app.photo_closet
    app.ranking
    app.monetization

[importlinter:contract:core-is-a-leaf]
name = Core must not import any other app layer
type = forbidden
source_modules =
    app.core
forbidden_modules =
    app.api
    app.services
    app.gmail_closet
    app.photo_closet
    app.ranking
    app.monetization
    app.platform
    app.models
    app.utils
    app.db
